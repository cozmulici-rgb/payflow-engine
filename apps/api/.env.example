APP_NAME="Payflow Engine"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ── MySQL / Aurora ────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=payflow
DB_USERNAME=payflow
DB_PASSWORD=secret
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0

CACHE_STORE=redis
CACHE_PREFIX=payflow_

SESSION_DRIVER=redis
SESSION_LIFETIME=120

QUEUE_CONNECTION=kafka

# ── Kafka / MSK ───────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISMS=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_CONSUMER_GROUP_ID=payflow-api
KAFKA_AUTO_OFFSET_RESET=latest

KAFKA_TOPIC_TRANSACTION_COMMANDS=transaction.processing
KAFKA_TOPIC_TRANSACTION_EVENTS=transaction.events
KAFKA_TOPIC_SETTLEMENT_EVENTS=settlement.events
KAFKA_TOPIC_WEBHOOK_EVENTS=webhook.events
KAFKA_TOPIC_AUDIT_EVENTS=audit.events

# ── ClickHouse ────────────────────────────────────────────────────────────────
CLICKHOUSE_HOST=127.0.0.1
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=payflow_analytics
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_HTTPS=false

# ── Operator ──────────────────────────────────────────────────────────────────
OPERATOR_SECRET=change-me-in-production

# ── Payment processing ────────────────────────────────────────────────────────
PAYMENT_IDEMPOTENCY_TTL=86400
PAYMENT_PROCESSOR_TIMEOUT_RETRIES=1
PAYMENT_DEFAULT_PROCESSOR=processor_a

# ── FX ───────────────────────────────────────────────────────────────────────
FX_LOCK_TTL_SECONDS=1800

# ── Settlement ────────────────────────────────────────────────────────────────
SETTLEMENT_ARTIFACT_DISK=s3
SETTLEMENT_ARTIFACT_BUCKET=payflow-settlement-artifacts

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ca-central-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Octane (production) ───────────────────────────────────────────────────────
OCTANE_SERVER=swoole
