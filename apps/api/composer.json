{
    "name": "payflow-engine/api",
    "description": "Payflow Engine API — high-volume financial transaction processing platform",
    "type": "project",
    "require": {
        "php": "^8.4",
        "ext-bcmath": "*",
        "ext-json": "*",
        "ext-pcntl": "*",
        "ext-rdkafka": "*",
        "laravel/framework": "^11.0",
        "laravel/octane": "^2.5",
        "mateusjunges/laravel-kafka": "^1.14",
        "predis/predis": "^2.3",
        "sanchescom/laravel-clickhouse": "^1.2"
    },
    "require-dev": {
        "behat/behat": "^3.15",
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.18",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/",
            "Modules\\": "../../modules/",
            "Database\\": "database/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Behat\\": "tests/Behat/bootstrap/"
        }
    },
    "scripts": {
        "behat": "behat --config behat.yml",
        "test": "php artisan test",
        "lint": "pint"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
