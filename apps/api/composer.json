{
  "name": "payflow-engine/api",
  "description": "Phase 01 bootstrap for Payflow Engine API",
  "type": "project",
  "require": {
    "php": ">=8.2"
  },
  "require-dev": {
    "behat/behat": "^3.15"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/",
      "Modules\\": "../../modules/",
      "Database\\": "database/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\Behat\\": "tests/Behat/bootstrap/"
    }
  },
  "scripts": {
    "behat": "behat --config behat.yml"
  }
}
