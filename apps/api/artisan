#!/usr/bin/env php
<?php

declare(strict_types=1);

require __DIR__ . '/bootstrap/app.php';

$app = bootstrap_app(__DIR__);
$command = $argv[1] ?? null;

if ($command === 'test') {
    $runner = new App\Support\TestRunner(__DIR__);
    exit($runner->run());
}

if ($command === 'settlement:run') {
    $batchDate = $argv[2] ?? gmdate('Y-m-d');
    $result = $app->runSettlementWindow($batchDate);
    fwrite(STDOUT, json_encode($result, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES) . PHP_EOL);
    exit($result['exception_count'] > 0 ? 1 : 0);
}

fwrite(STDERR, "Unknown or missing command. Supported: test, settlement:run\n");
exit(1);
